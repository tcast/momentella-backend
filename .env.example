# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Better Auth — use `openssl rand -base64 32`
BETTER_AUTH_SECRET=""
# Public URL of this API (no trailing slash), e.g. https://api.momentella.com
BETTER_AUTH_URL="http://localhost:4000"

# Browser origins allowed for cookies + CORS (Next.js apps)
CLIENT_APP_ORIGIN="http://localhost:3000"
ADMIN_APP_ORIGIN="http://localhost:3001"

# Optional: Resend for magic-link email in production
# RESEND_API_KEY="re_..."

# Server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
