{
  "name": "momentella-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Momentella API — client portal, admin, auth (Better Auth + Prisma + PostgreSQL)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "auth:generate": "npx auth@latest generate --config ./src/lib/auth.ts -y --output prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "admin:create": "tsx scripts/create-admin.ts",
    "seed:places": "tsx scripts/seed-places.ts",
    "seed:pages": "tsx scripts/seed-pages.ts",
    "upgrade:family-trip-form": "tsx scripts/upgrade-family-trip-form.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@prisma/client": "^6.19.3",
    "better-auth": "^1.6.5",
    "fastify": "^5.8.5",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
