generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String      @id
  name             String
  email            String
  emailVerified    Boolean     @default(false)
  image            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  twoFactorEnabled Boolean?    @default(false)
  role             String?
  banned           Boolean?    @default(false)
  banReason        String?
  banExpires       DateTime?
  sessions         Session[]
  accounts         Account[]
  twofactors       TwoFactor[]
  trips             Trip[]
  bookingRequests   BookingRequest[]
  intakeSubmissions IntakeSubmission[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String   @id
  secret      String
  backupCodes String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean? @default(true)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

enum TripStatus {
  DRAFT
  PROPOSED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum BookingRequestStatus {
  NEW
  IN_REVIEW
  RESPONDED
  CLOSED
}

model Trip {
  id          String     @id @default(cuid())
  clientId    String
  title       String
  destination String?
  status      TripStatus @default(DRAFT)
  summary     String?
  startsOn    DateTime?
  endsOn      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  client      User       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model BookingRequest {
  id        String               @id @default(cuid())
  clientId  String?
  email     String
  status    BookingRequestStatus @default(NEW)
  payload   Json
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  client    User?                @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([clientId])
}

/// Configurable trip intake: multiple forms, versioned definitions (JSON schema).
model IntakeForm {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String?
  archived    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  versions    IntakeFormVersion[]
  submissions IntakeSubmission[]

  @@map("intake_form")
}

model IntakeFormVersion {
  id         String   @id @default(cuid())
  formId     String
  version    Int
  label      String?
  /// JSON: { version: 1, fields: FormField[] }
  schema     Json
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  form       IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  submissions IntakeSubmission[]

  @@unique([formId, version])
  @@index([formId])
  @@map("intake_form_version")
}

enum IntakeSubmissionStatus {
  NEW
  IN_REVIEW
  RESPONDED
  CLOSED
}

/// Commercial airports — used by the `airport` intake field.
model Airport {
  id          String   @id @default(cuid())
  iata        String   @unique
  icao        String?
  name        String
  city        String
  region      String?
  country     String
  countryCode String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([city])
  @@index([country])
  @@map("airport")
}

enum DestinationType {
  COUNTRY
  REGION
  CITY
  AREA
  PARK
  RESORT
  VENUE
}

/// Trip destinations — used by the `destination` intake field.
model Destination {
  id        String          @id @default(cuid())
  slug      String          @unique
  name      String
  type      DestinationType
  country   String?
  region    String?
  aliases   String?
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([type])
  @@index([country])
  @@index([active])
  @@map("destination")
}

/// Editable marketing pages (home + additional). Versioned JSON block list. Slug `home` drives `/`.
model MarketingPage {
  id          String                 @id @default(cuid())
  slug        String                 @unique
  name        String
  description String?
  archived    Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  versions    MarketingPageVersion[]

  @@map("marketing_page")
}

model MarketingPageVersion {
  id        String        @id @default(cuid())
  pageId    String
  version   Int
  label     String?
  /// JSON: { version: 1, blocks: PageBlock[] }
  schema    Json
  published Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  page      MarketingPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, version])
  @@index([pageId])
  @@map("marketing_page_version")
}

model IntakeSubmission {
  id            String                 @id @default(cuid())
  formId        String
  formVersionId String
  email         String
  status        IntakeSubmissionStatus @default(NEW)
  /// Answers keyed by field id (JSON-serializable values).
  responses     Json
  clientId      String?
  /// @deprecated — legacy single-note column; see `notesThread`.
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  form          IntakeForm             @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersion   IntakeFormVersion      @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  client        User?                  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  notesThread   IntakeSubmissionNote[]

  @@index([formId])
  @@index([email])
  @@index([clientId])
  @@map("intake_submission")
}

/// Timestamped notes on a submission (internal CRM log). Many per submission.
model IntakeSubmissionNote {
  id           String           @id @default(cuid())
  submissionId String
  /// Admin user who wrote the note. Nullable so deleting the user doesn't
  /// erase the history; `authorName` preserves attribution.
  authorId     String?
  authorName   String?
  body         String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  submission   IntakeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("intake_submission_note")
}
