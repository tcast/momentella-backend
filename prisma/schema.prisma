generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String      @id
  name             String
  email            String
  emailVerified    Boolean     @default(false)
  image            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  twoFactorEnabled Boolean?    @default(false)
  role             String?
  banned           Boolean?    @default(false)
  banReason        String?
  banExpires       DateTime?
  sessions         Session[]
  accounts         Account[]
  twofactors       TwoFactor[]
  trips             Trip[]
  bookingRequests   BookingRequest[]
  intakeSubmissions IntakeSubmission[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String   @id
  secret      String
  backupCodes String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean? @default(true)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

enum TripStatus {
  DRAFT
  PROPOSED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum BookingRequestStatus {
  NEW
  IN_REVIEW
  RESPONDED
  CLOSED
}

model Trip {
  id          String     @id @default(cuid())
  clientId    String
  title       String
  destination String?
  status      TripStatus @default(DRAFT)
  summary     String?
  startsOn    DateTime?
  endsOn      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  client      User       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model BookingRequest {
  id        String               @id @default(cuid())
  clientId  String?
  email     String
  status    BookingRequestStatus @default(NEW)
  payload   Json
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  client    User?                @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([clientId])
}

/// Configurable trip intake: multiple forms, versioned definitions (JSON schema).
model IntakeForm {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String?
  archived    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  versions    IntakeFormVersion[]
  submissions IntakeSubmission[]

  @@map("intake_form")
}

model IntakeFormVersion {
  id         String   @id @default(cuid())
  formId     String
  version    Int
  label      String?
  /// JSON: { version: 1, fields: FormField[] }
  schema     Json
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  form       IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  submissions IntakeSubmission[]

  @@unique([formId, version])
  @@index([formId])
  @@map("intake_form_version")
}

enum IntakeSubmissionStatus {
  NEW
  IN_REVIEW
  RESPONDED
  CLOSED
}

model IntakeSubmission {
  id            String                 @id @default(cuid())
  formId        String
  formVersionId String
  email         String
  status        IntakeSubmissionStatus @default(NEW)
  /// Answers keyed by field id (JSON-serializable values).
  responses     Json
  clientId      String?
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  form          IntakeForm             @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersion   IntakeFormVersion      @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  client        User?                  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([formId])
  @@index([email])
  @@index([clientId])
  @@map("intake_submission")
}
