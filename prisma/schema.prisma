generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String      @id
  name             String
  email            String
  emailVerified    Boolean     @default(false)
  image            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  twoFactorEnabled Boolean?    @default(false)
  role             String?
  banned           Boolean?    @default(false)
  banReason        String?
  banExpires       DateTime?
  sessions         Session[]
  accounts         Account[]
  twofactors       TwoFactor[]
  trips             Trip[]
  bookingRequests   BookingRequest[]
  intakeSubmissions IntakeSubmission[]
  ordersBought      Order[]            @relation("OrderBuyer")
  giftsRedeemed     GiftCertificate[]  @relation("GiftRedeemer")

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String   @id
  secret      String
  backupCodes String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean? @default(true)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

enum TripStatus {
  /// Fresh — usually created from an intake submission.
  LEAD
  /// Internal planning underway.
  PLANNING
  /// Proposal published to the client.
  PROPOSED
  /// Bookings confirmed. (legacy: CONFIRMED)
  BOOKED
  /// Travelers are on the trip right now.
  IN_PROGRESS
  /// Trip is over.
  COMPLETED
  ARCHIVED

  // Deprecated values kept so any pre-existing rows still parse.
  DRAFT
  CONFIRMED
}

enum TripKind {
  /// Momentella designs and books the entire trip.
  FULL_SERVICE
  /// Momentella designs the itinerary; the client books on their own.
  ITINERARY_ONLY
  /// One-off consult / advice (no full itinerary).
  CONSULT
}

enum BookingRequestStatus {
  NEW
  IN_REVIEW
  RESPONDED
  CLOSED
}

/// One trip per request. A client can have many over time. A trip is the
/// hub the rest of the planning hangs off (itinerary, proposals, bookings,
/// notes, messages — added in later phases).
model Trip {
  id          String     @id @default(cuid())
  clientId    String
  title       String
  /// Plain-text summary destination (legacy / fallback).
  destination String?
  kind        TripKind   @default(FULL_SERVICE)
  status      TripStatus @default(LEAD)
  summary     String?

  // Travel basics — copied from the intake when converted, freely editable
  // afterward. Stored on Trip so the original IntakeSubmission stays a
  // historical record.
  startsOn        DateTime?
  endsOn          DateTime?
  homeAirportIata String?
  partyAdults     Int?
  partyChildren   Int?
  /// JSON array of child ages (numbers).
  partyChildAges  Json?
  /// value | mid | luxury | ultra | discuss (free-form to stay flexible).
  budgetTier      String?
  /// JSON array of {id, slug, name, type, country, region}.
  destinations    Json?
  /// Day-by-day itinerary as a versioned JSON document. Phase-2 schema
  /// shape lives in `lib/itinerary-schema.ts` on the frontend (mirrored
  /// types on the backend). Null until an admin builds one.
  itinerarySchema Json?

  // One-to-one back-pointer to the intake submission this trip came from.
  originIntakeSubmissionId String?           @unique
  originIntakeSubmission   IntakeSubmission? @relation("TripFromIntake", fields: [originIntakeSubmissionId], references: [id], onDelete: SetNull)

  notes     TripNote[]
  proposals Proposal[]
  messages  TripMessage[]
  bookings  Booking[]
  documents TripDocument[]

  /// When this trip was created from a paid order, the order it fulfills.
  fulfilledByOrderId String?
  fulfilledByOrder   Order?  @relation("OrderTrips", fields: [fulfilledByOrderId], references: [id], onDelete: SetNull)
  /// When this trip was created from a redeemed gift certificate, the cert.
  redeemedFromGift   GiftCertificate? @relation("GiftRedeemedTrip")
  /// SKU that fulfilled this trip (for display: "2-day itinerary").
  productSlug        String?
  /// 1, 2, or 3 — soft cap shown in the itinerary builder. null = uncapped.
  itineraryDaysAllowed Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    User     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@index([kind])
  @@index([fulfilledByOrderId])
}

/// Internal admin notes on a trip (not visible to clients). Same threaded
/// shape as IntakeSubmissionNote.
model TripNote {
  id         String   @id @default(cuid())
  tripId     String
  authorId   String?
  authorName String?
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("trip_note")
}

enum ProposalStatus {
  /// Just published — the client hasn't acted yet.
  SENT
  /// Client approved this version.
  APPROVED
  /// Client requested changes (see responseNote).
  CHANGES_REQUESTED
  /// Admin pulled this version back.
  WITHDRAWN
}

/// Frozen snapshot of a trip + its itinerary that the admin sends to the
/// client. New version per round of feedback. Stored on disk as JSON so the
/// client always sees what was sent, regardless of later edits to the
/// working `Trip.itinerarySchema`.
model Proposal {
  id              String         @id @default(cuid())
  tripId          String
  trip            Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  /// Per-trip auto-incrementing version (1, 2, 3, …).
  version         Int
  /// JSON: { version, trip: {…}, itinerary: ItinerarySchema, message? }
  schema          Json
  status          ProposalStatus @default(SENT)
  /// Optional message from the admin attached at publish time.
  message         String?
  publishedById   String?
  publishedByName String?
  respondedAt     DateTime?
  responderId     String?
  responderName   String?
  /// Optional note from the client (e.g. their change requests).
  responseNote    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([tripId, version])
  @@index([tripId])
  @@map("proposal")
}

/// Conversation thread between the admin team and the client for a trip.
/// `authorRole` is captured at write time so re-roling a user later doesn't
/// rewrite the past.
model TripMessage {
  id         String   @id @default(cuid())
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  authorId   String?
  authorName String?
  /// "admin" | "client"
  authorRole String
  body       String
  createdAt  DateTime @default(now())

  @@index([tripId, createdAt])
  @@map("trip_message")
}

enum BookingKind {
  LODGING
  FLIGHT
  TRANSFER
  ACTIVITY
  CRUISE
  CAR_RENTAL
  RAIL
  INSURANCE
  OTHER
}

enum BookingStatus {
  /// Saved internally; not actually booked yet.
  DRAFT
  /// Held with the supplier; awaiting confirmation.
  PENDING
  /// Booked + confirmed.
  CONFIRMED
  CANCELLED
}

/// Operational ledger of bookings for a trip. The itinerary describes the
/// experience; the booking row is the source of truth for "what's actually
/// reserved, with whom, for how much, under what reference."
model Booking {
  id          String         @id @default(cuid())
  tripId      String
  trip        Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  kind        BookingKind
  status      BookingStatus  @default(DRAFT)
  title       String
  vendorName  String?
  /// Free-form URL — typically the Fora link or supplier confirmation page.
  vendorUrl   String?
  bookingRef  String?
  /// "us" (Momentella) or "them" (client books on their own).
  bookedBy    String?
  startDate   DateTime?
  endDate     DateTime?
  /// Total cost in trip currency (USD assumed for v1).
  cost        Float?
  costNotes   String?
  /// Visible to the client.
  description String?
  /// Admin-only.
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  documents TripDocument[]

  @@index([tripId])
  @@index([status])
  @@map("booking")
}

/// Files attached to a trip (or a specific Booking). Stored on the same R2
/// bucket as image uploads. `visibleToClient` defaults true so vouchers and
/// confirmations show up on the family's portal automatically.
model TripDocument {
  id              String   @id @default(cuid())
  tripId          String
  trip            Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  bookingId       String?
  booking         Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  name            String
  storageKey      String
  url             String
  contentType     String
  size            Int
  visibleToClient Boolean  @default(true)
  uploadedById    String?
  uploadedByName  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tripId])
  @@index([bookingId])
  @@map("trip_document")
}

model BookingRequest {
  id        String               @id @default(cuid())
  clientId  String?
  email     String
  status    BookingRequestStatus @default(NEW)
  payload   Json
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  client    User?                @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([clientId])
}

enum ProductKind {
  /// 1, 2, or 3-day itinerary planning (others may follow).
  ITINERARY_PLANNING
}

/// Sellable services. Stripe is the source of truth for pricing; we mirror
/// the price + Stripe Price ID here for fast display + product-management UI.
model Product {
  id            String      @id @default(cuid())
  slug          String      @unique
  kind          ProductKind
  name          String
  description   String?
  /// Number of itinerary days included (when kind == ITINERARY_PLANNING).
  itineraryDays Int?
  /// Cents, USD.
  priceCents    Int
  /// Live Stripe Price ID (price_…). Filled in once synced.
  stripePriceId String?
  active        Boolean     @default(true)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  orders Order[]

  @@map("product")
}

enum OrderStatus {
  /// Stripe Checkout session created; waiting for payment.
  PENDING
  /// Payment succeeded; fulfillment complete (trip + emails).
  PAID
  /// Buyer abandoned the Stripe Checkout flow.
  CANCELLED
  /// Stripe webhook reported failure.
  FAILED
  /// Refunded after payment.
  REFUNDED
}

/// One purchase = one Order. Single-item for v1 (no cart).
model Order {
  id             String      @id @default(cuid())
  buyerId        String?
  buyer          User?       @relation("OrderBuyer", fields: [buyerId], references: [id], onDelete: SetNull)
  /// Always captured even when the buyer doesn't have / need an account
  /// (e.g. one-shot gift purchase).
  buyerEmail     String
  buyerName      String?

  productId      String
  product        Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  /// Snapshot of the price at purchase time so later edits don't rewrite history.
  unitPriceCents Int
  quantity       Int         @default(1)
  totalCents     Int

  status         OrderStatus @default(PENDING)
  isGift         Boolean     @default(false)

  // Stripe linkage
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?

  paidAt     DateTime?
  refundedAt DateTime?

  /// Free-form admin notes.
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Trips fulfilled by this order. For self-purchase, exactly one — created
  /// at payment time. For a gift, zero until the recipient redeems, then one.
  trips           Trip[]            @relation("OrderTrips")
  giftCertificate GiftCertificate?

  @@index([buyerId])
  @@index([buyerEmail])
  @@index([status])
  @@map("order")
}

model GiftCertificate {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  /// Short, URL-safe redemption code, e.g. "MOM-7K9Q-PXR3".
  code String @unique

  recipientEmail String
  recipientName  String?
  /// Optional personal message from the buyer.
  message        String?

  /// When the gift email was scheduled to be sent (null = immediate).
  scheduledFor DateTime?
  sentAt       DateTime?

  redeemedAt     DateTime?
  redeemedById   String?
  redeemedBy     User?     @relation("GiftRedeemer", fields: [redeemedById], references: [id], onDelete: SetNull)
  /// The Trip created from redemption.
  redeemedTripId String?   @unique
  redeemedTrip   Trip?     @relation("GiftRedeemedTrip", fields: [redeemedTripId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipientEmail])
  @@index([redeemedById])
  @@map("gift_certificate")
}

/// Configurable trip intake: multiple forms, versioned definitions (JSON schema).
model IntakeForm {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String?
  archived    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  versions    IntakeFormVersion[]
  submissions IntakeSubmission[]

  @@map("intake_form")
}

model IntakeFormVersion {
  id         String   @id @default(cuid())
  formId     String
  version    Int
  label      String?
  /// JSON: { version: 1, fields: FormField[] }
  schema     Json
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  form       IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  submissions IntakeSubmission[]

  @@unique([formId, version])
  @@index([formId])
  @@map("intake_form_version")
}

enum IntakeSubmissionStatus {
  NEW
  IN_REVIEW
  RESPONDED
  CLOSED
}

/// Commercial airports — used by the `airport` intake field.
model Airport {
  id          String   @id @default(cuid())
  iata        String   @unique
  icao        String?
  name        String
  city        String
  region      String?
  country     String
  countryCode String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([city])
  @@index([country])
  @@map("airport")
}

enum DestinationType {
  COUNTRY
  REGION
  CITY
  AREA
  PARK
  RESORT
  VENUE
}

/// Trip destinations — used by the `destination` intake field.
model Destination {
  id        String          @id @default(cuid())
  slug      String          @unique
  name      String
  type      DestinationType
  country   String?
  region    String?
  aliases   String?
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([type])
  @@index([country])
  @@index([active])
  @@map("destination")
}

/// Editable marketing pages (home + additional). Versioned JSON block list. Slug `home` drives `/`.
model MarketingPage {
  id          String                 @id @default(cuid())
  slug        String                 @unique
  name        String
  description String?
  archived    Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  versions    MarketingPageVersion[]

  @@map("marketing_page")
}

model MarketingPageVersion {
  id        String        @id @default(cuid())
  pageId    String
  version   Int
  label     String?
  /// JSON: { version: 1, blocks: PageBlock[] }
  schema    Json
  published Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  page      MarketingPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, version])
  @@index([pageId])
  @@map("marketing_page_version")
}

model IntakeSubmission {
  id            String                 @id @default(cuid())
  formId        String
  formVersionId String
  email         String
  status        IntakeSubmissionStatus @default(NEW)
  /// Answers keyed by field id (JSON-serializable values).
  responses     Json
  clientId      String?
  /// @deprecated — legacy single-note column; see `notesThread`.
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  form          IntakeForm             @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersion   IntakeFormVersion      @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  client        User?                  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  notesThread   IntakeSubmissionNote[]
  convertedTrip Trip?                  @relation("TripFromIntake")

  @@index([formId])
  @@index([email])
  @@index([clientId])
  @@map("intake_submission")
}

/// Timestamped notes on a submission (internal CRM log). Many per submission.
model IntakeSubmissionNote {
  id           String           @id @default(cuid())
  submissionId String
  /// Admin user who wrote the note. Nullable so deleting the user doesn't
  /// erase the history; `authorName` preserves attribution.
  authorId     String?
  authorName   String?
  body         String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  submission   IntakeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("intake_submission_note")
}
